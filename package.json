{
  "name": "healthcore-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "HealthCore AI Engineering monorepo — Milestone 1 static site at repo root",
  "scripts": {
    "start": "http-server . -p 3000 -a 0.0.0.0 -c-1",
    "vercel": "vercel",
    "vercel:login": "vercel login",
    "vercel:link": "vercel link --scope danielcruz-glitchs-projects",
    "vercel:deploy": "vercel deploy --prod --yes --scope danielcruz-glitchs-projects",
    "vercel:whoami": "vercel whoami"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "vercel": "^54.14.5"
  }
}
